{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024",
    "baseUrl": ".",
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "outDir": "./dist"
  },
  "exclude": ["**/node_modules/*", "src/**/*.test.ts"],
  "include": ["src", "src/**/*.ts"],
  "references": [
    { "path": "../../libs/types" },
    { "path": "../../libs/sparques-canvas" }
  ]
}
